# Copy to .env for local dev; set the same vars in the Vercel dashboard for deploys.
#
# VITE_* are PUBLIC — inlined into the client bundle at build time.
# The non-VITE copies are read server-side (SSR auth) per request.
# The Supabase publishable/anon key is safe to expose; never put a service-role key here.

SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
